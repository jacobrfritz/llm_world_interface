# .env.example
# Copy this file to .env and fill in the values

# Obsidian Configuration
# The path to your local Obsidian vault directory
OBSIDIAN_VAULT_PATH="./my_vault"

# LLM Configuration
# Choose the provider for the agent (e.g., "gemini" or "openai")
LLM_PROVIDER="gemini"
# The model name to use for the selected provider
LLM_MODEL_NAME="gemini-2.5-flash"
# Temperature for LLM sampling (0.0 for deterministic, higher for more creative)
LLM_TEMPERATURE=0.2

# LLM Provider API Keys
# Required if LLM_PROVIDER="gemini"
GEMINI_API_KEY="your-gemini-api-key-here"

# Required if LLM_PROVIDER="openai"
OPENAI_API_KEY="your-openai-api-key-here"
